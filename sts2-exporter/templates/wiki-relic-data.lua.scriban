return { {{ for relic in relics }}
  ["{{ relic.id }}"] = {
    ID = "{{ relic.id }}",
    Name = "{{ relic.name }}",
    Description = "{{ relic.description }}",
    Character = "{{ relic.pool }}",{{ if relic.ancient != null }}
    Ancient = "{{ relic.ancient }}",{{ end }}
    Rarity = "{{ relic.rarity }}",
    Flavor = "{{ relic.flavor }}",
  },{{ end }}
}